# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM provider: groq | anthropic | openai | ollama ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Provider credentials (set the one matching LLM_PROVIDER) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434   # if using a local Ollama model

# --- Retrieval-Augmented Generation (RAG) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4

# --- Agent behaviour ---
MAX_SEARCH_RESULTS=5
RECURSION_LIMIT=25


# ----- Hugging Face Tokens (if using a Hugging Face model) -----
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HF_TOKEN=