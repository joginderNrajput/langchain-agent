# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM provider: groq | anthropic | openai | azure | gemini | ollama ---
LLM_PROVIDER=groq
# LLM_MODEL is optional — leave unset to use the selected provider's default.
# Set it only to override. Defaults per provider:
#   groq:      llama-3.3-70b-versatile
#   openai:    gpt-4o-mini
#   anthropic: claude-sonnet-4-6
#   gemini:    gemini-2.5-flash
#   ollama:    llama3.1
#   azure:     uses AZURE_OPENAI_DEPLOYMENT (no LLM_MODEL needed)
LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Provider credentials (set the one matching LLM_PROVIDER) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Gemini — get a free key at https://aistudio.google.com/apikey (GOOGLE_API_KEY or GEMINI_API_KEY):
# GEMINI_API_KEY=
# Azure OpenAI (set LLM_PROVIDER=azure). The deployment name is the "model".
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-10-21
# OLLAMA_BASE_URL=http://localhost:11434   # if using a local Ollama model

# --- Retrieval-Augmented Generation (RAG) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4

# --- Agent behaviour ---
MAX_SEARCH_RESULTS=5
RECURSION_LIMIT=25


# ----- Hugging Face Tokens (if using a Hugging Face model) -----
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HF_TOKEN=

# ─────────────────────────────────────────────────────────────
# Production / API settings
# ─────────────────────────────────────────────────────────────

# --- Resilience ---
LLM_MAX_RETRIES=2          # provider retries on 429/5xx

# --- Conversation state: memory | sqlite | postgres ---
CHECKPOINTER=memory
# SQLITE_PATH=data/checkpoints.sqlite
# Required when CHECKPOINTER=postgres (install extra: uv sync --extra postgres):
# POSTGRES_DSN=postgresql://user:pass@host:5432/dbname

# --- HTTP API server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
REQUEST_TIMEOUT_SECONDS=120
MAX_QUESTION_CHARS=4000

# --- API authentication (comma-separated keys; empty = auth disabled) ---
API_KEYS=
# --- CORS (comma-separated origins, or *) ---
CORS_ORIGINS=*

# --- Rate limiting (per API key / client IP) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# --- Observability: LangSmith tracing ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-research-agent